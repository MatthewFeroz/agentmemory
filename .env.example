# =============================================================================
# .env.example — Template for required environment variables
# =============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit the actual .env file — it contains secrets.
# This .example file is safe to commit because it has no real keys.
# =============================================================================

# --- Anthropic API key -------------------------------------------------------
# Get yours at https://console.anthropic.com/settings/keys
# The Anthropic SDK reads this automatically; we also validate it at startup
# via our pydantic-settings config so you get a clear error if it's missing.
ANTHROPIC_API_KEY=your-api-key-here

# --- Redis Agent Memory Server ------------------------------------------------
# Run Redis Agent Memory Server locally and expose it on a stable port.
#
# Redis Agent Memory Server repo:
#   https://github.com/redis/agent-memory-server
#
# Recommended demo URL:
#   http://localhost:8001
#
# If your local setup uses a different port, override this in your real .env.
MEMORY_API_URL=http://localhost:8001

# Optional namespace for grouping memories inside the memory server.
# Leaving this blank is fine for the simplest possible demo.
MEMORY_NAMESPACE=
