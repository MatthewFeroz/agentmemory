# =============================================================================
# .env.example - Shared local environment template
# =============================================================================
# Copy this file to `.env` and replace placeholder values with real secrets.
#
# This project uses one shared `.env` file for two different processes:
# 1. The FastAPI app in `backend/app`
# 2. Redis Agent Memory Server (AMS)
#
# Important architecture note:
# - The FastAPI app talks to Claude and to AMS
# - AMS talks to Redis and manages memory storage/retrieval
# - Some variables below belong to the FastAPI app
# - Some belong to AMS
#
# The backend config now ignores unknown env vars on purpose, so it is safe
# for one `.env` file to contain both sets of values.
# =============================================================================

# =============================================================================
# FastAPI app settings
# =============================================================================

# Required: Anthropic API key used by the app when it calls Claude directly.
# Get one from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: Claude model used by the FastAPI app for chat responses.
# Good interview/demo default:
#   claude-haiku-4-5 for speed
# More capable option:
#   claude-sonnet-4-6
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: Max tokens for one Claude response from the app backend.
MAX_TOKENS=1024

# Required for memory features: base URL of the running AMS HTTP API.
# Example local URL if AMS is mapped to port 32769:
#   http://localhost:32769
MEMORY_API_URL=http://localhost:32769

# Optional: namespace for isolating memories in AMS.
# Leave blank for the simplest setup.
MEMORY_NAMESPACE=

# Optional: stable fallback user identity for long-term demo mode when the
# frontend does not send one explicitly.
DEFAULT_LONG_TERM_USER_ID=demo-long-term-user

# Optional: use AMS native semantic long-term search only when AMS is fully
# configured with a working embedding provider.
PREFER_AMS_LONG_TERM_SEARCH=false


# =============================================================================
# Agent Memory Server settings
# =============================================================================
# These variables are read by the AMS process, not by the FastAPI app.
# If AMS is started without them, long-term semantic memory may not work.

# Anthropic models used by AMS for generation/extraction tasks.
GENERATION_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5

# Embedding provider choice for AMS long-term semantic search.
# This project currently uses Redis's Hugging Face embedding model.
EMBEDDING_MODEL=huggingface/redis/langcache-embed-v3-small
REDISVL_VECTOR_DIMENSIONS=384

# Hugging Face token for hosted inference.
# Get one from: https://huggingface.co/settings/tokens
# We set both names because different integrations may expect either one.
HF_TOKEN=your-hugging-face-token
HUGGINGFACE_API_KEY=your-hugging-face-token

# Optional alternative if you switch AMS embeddings to OpenAI instead:
# OPENAI_API_KEY=your-openai-api-key
# EMBEDDING_MODEL=text-embedding-3-small
# REDISVL_VECTOR_DIMENSIONS=1536

# Enable AMS long-term memory features.
LONG_TERM_MEMORY=true
ENABLE_DISCRETE_MEMORY_EXTRACTION=true

# Redis connection used by AMS.
# This should point at the Redis instance that AMS manages memory in.
REDIS_URL=redis://localhost:6379

# Local demo mode: disable AMS auth.
DISABLE_AUTH=true