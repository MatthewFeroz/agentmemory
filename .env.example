# Copy to `.env` and replace placeholder values.

# Docker image pins
AMS_IMAGE_TAG=0.15.2
REDIS_IMAGE_TAG=8.6.2

# Host ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
AMS_PORT=32769
REDIS_PORT=6379

# Backend
# Anthropic keys: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5
MAX_TOKENS=1024
MEMORY_API_URL=http://localhost:32769
MEMORY_NAMESPACE=
DEFAULT_LONG_TERM_USER_ID=demo-long-term-user
PREFER_AMS_LONG_TERM_SEARCH=false

# Agent Memory Server
GENERATION_MODEL=claude-sonnet-4-6
FAST_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=huggingface/redis/langcache-embed-v3-small
REDISVL_VECTOR_DIMENSIONS=384
# Hugging Face tokens: https://huggingface.co/settings/tokens
HF_TOKEN=your-hugging-face-token
HUGGINGFACE_API_KEY=your-hugging-face-token
LONG_TERM_MEMORY=true
ENABLE_DISCRETE_MEMORY_EXTRACTION=true
REDIS_URL=redis://localhost:6379
DISABLE_AUTH=true

# Optional AMS alternative for embeddings
# OpenAI API keys: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key
# EMBEDDING_MODEL=text-embedding-3-small
# REDISVL_VECTOR_DIMENSIONS=1536

# Docker Compose overrides internal service URLs automatically:
# - MEMORY_API_URL -> http://agent-memory-server:8000
# - REDIS_URL -> redis://redis:6379
