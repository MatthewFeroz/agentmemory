# =============================================================================
# .env.example — Template for required environment variables
# =============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit the actual .env file — it contains secrets.
# This .example file is safe to commit because it has no real keys.
# =============================================================================

# --- Anthropic API key -------------------------------------------------------
# Get yours at https://console.anthropic.com/settings/keys
# The Anthropic SDK reads this automatically; we also validate it at startup
# via our pydantic-settings config so you get a clear error if it's missing.
ANTHROPIC_API_KEY=your-api-key-here
